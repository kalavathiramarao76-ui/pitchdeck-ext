{
  "manifest_version": 3,
  "name": "PitchDeck AI",
  "version": "1.0.0",
  "description": "AI-powered pitch deck generator, elevator pitch creator, and investor tools for startups",
  "permissions": ["sidePanel", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.angellist.com/*",
    "https://angel.co/*",
    "https://www.crunchbase.com/*",
    "https://sai.sharedllm.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.angellist.com/*",
        "https://angel.co/*",
        "https://www.crunchbase.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
