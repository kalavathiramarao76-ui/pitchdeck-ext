{
  "manifest_version": 3,
  "name": "DeckForge \u2014 AI Pitch Deck Generator & Startup Tools",
  "version": "1.0.0",
  "description": "AI pitch deck generator: create investor-ready decks, elevator pitches & startup analysis. Free Chrome extension.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.angellist.com/*",
    "https://angel.co/*",
    "https://www.crunchbase.com/*",
    "https://sai.sharedllm.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.angellist.com/*",
        "https://angel.co/*",
        "https://www.crunchbase.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "short_name": "DeckForge"
}
